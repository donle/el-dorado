# 强制 LF 换行（避免 Windows git 客户端把 .sh / Dockerfile 转成 CRLF，
# 导致 Linux 服务器上 shebang 解析失败）
*           text=auto eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf
*.env*      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.ts        text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
